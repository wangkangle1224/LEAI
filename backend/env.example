# LEAI Backend Environment Variables
# 复制此文件为 .env.local 并填入你的实际配置

# ============================================
# Supabase 配置
# ============================================
# 获取地址: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# Banana AI API 配置 (后端代理使用)
# ============================================
BANANA_API_KEY=sk-your-banana-api-key
BANANA_API_URL=https://api.vectorengine.ai

# ============================================
# DeepSeek API 配置 (提示词优化使用)
# ============================================
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 阿里云短信配置
# ============================================
# 获取地址: https://dysms.console.aliyun.com/
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SIGN_NAME=您的签名名称
ALIYUN_TEMPLATE_CODE=SMS_123456789

# ============================================
# 服务器配置
# ============================================
PORT=3001
NODE_ENV=development
